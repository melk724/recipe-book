# Anthropic Claude API (recipe extraction)
ANTHROPIC_API_KEY=sk-ant-...

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Service role key - REQUIRED for multi-user mode (used server-side only)
# Get this from Supabase: Project Settings → API → service_role secret
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Spotify
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
NEXT_PUBLIC_SPOTIFY_REDIRECT_URI=

# Optional - explicit site URL (overrides VERCEL_URL for redirect URI inference)
NEXT_PUBLIC_SITE_URL=

# YouTube Data API v3 (for music recommendations on YouTube)
# Get a free key at https://console.cloud.google.com - enable "YouTube Data API v3"
YOUTUBE_API_KEY=
